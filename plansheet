<script>
// Progress bar
window.addEventListener('scroll',()=>{
  const p=(window.scrollY/(document.body.scrollHeight-window.innerHeight))*100;
  document.getElementById('doc-progress').style.width=p+'%';
  document.getElementById('btt').classList.toggle('show',window.scrollY>400);
});

// Fade-in observer
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible');});},{threshold:.08});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

// Collapsible feature cards
function toggleCard(header){
  const card=header.closest('.feature-card');
  const body=card.querySelector('.fc-body');
  const isOpen=card.classList.contains('open');
  card.classList.toggle('open',!isOpen);
  body.classList.toggle('open',!isOpen);
}

// Sticky nav active state on scroll
const sections=['roadmap','pitch','admin','competition','risks','phasing'];
const navItems=document.querySelectorAll('.nav-item');
const obs2=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const id=e.target.id;
      navItems.forEach(n=>{
        n.classList.toggle('active',n.getAttribute('href')==='#'+id);
      });
    }
  });
},{threshold:.2,rootMargin:'-60px 0px -60% 0px'});
sections.forEach(id=>{const el=document.getElementById(id);if(el)obs2.observe(el);});

// Open first card in each section on load after slight delay
setTimeout(()=>{
  const firstCards=document.querySelectorAll('.feature-card');
  if(firstCards.length>0){
    const h=firstCards[0].querySelector('.fc-header');
    toggleCard(h);
  }
},800);
</script>
