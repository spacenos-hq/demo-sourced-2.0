<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sourced by Dibbs 2.0 — Master Specification</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0B0C0E;
  --surface: #111316;
  --surface2: #181B1F;
  --surface3: #1E2228;
  --border: rgba(255,255,255,.07);
  --border2: rgba(255,255,255,.12);
  --gold: #D4A843;
  --gold2: #F0C96A;
  --gold-dim: rgba(212,168,67,.15);
  --gold-border: rgba(212,168,67,.25);
  --white: #F2EDE4;
  --mist: #7A8091;
  --mist2: #9BA3B2;
  --teal: #3ECFB2;
  --teal-dim: rgba(62,207,178,.12);
  --red: #E85D5D;
  --red-dim: rgba(232,93,93,.12);
  --blue: #5B9CF6;
  --blue-dim: rgba(91,156,246,.12);
  --green: #52C97B;
  --green-dim: rgba(82,201,123,.12);
  --amber: #F0A84E;
  --amber-dim: rgba(240,168,78,.12);
  --purple: #A87FE8;
  --purple-dim: rgba(168,127,232,.12);
  --r: 8px;
  --r2: 12px;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { font-family:'DM Sans',sans-serif; background:var(--black); color:var(--white); overflow-x:hidden; line-height:1.6; }
::selection { background:var(--gold-dim); color:var(--gold2); }
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:var(--surface); }
::-webkit-scrollbar-thumb { background:var(--gold); border-radius:2px; }

/* ── COVER ── */
.cover {
  min-height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  padding:0;
  position:relative;
  overflow:hidden;
  background:var(--black);
}
.cover-noise {
  position:absolute;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;
}
.cover-grid {
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(212,168,67,.06) 1px,transparent 1px),
    linear-gradient(90deg,rgba(212,168,67,.06) 1px,transparent 1px);
  background-size:48px 48px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  z-index:0;
}
.cover-glow {
  position:absolute;
  top:-20%;left:50%;transform:translateX(-50%);
  width:900px;height:600px;
  background:radial-gradient(ellipse, rgba(212,168,67,.12) 0%, transparent 65%);
  z-index:0;pointer-events:none;
}
.cover-main {
  position:relative;z-index:2;
  padding:clamp(60px,8vw,120px) clamp(24px,6vw,80px) 0;
}
.cover-eyebrow {
  display:inline-flex;align-items:center;gap:8px;
  font-family:'DM Mono',monospace;
  font-size:11px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--gold);
  margin-bottom:32px;
}
.cover-eyebrow::before {
  content:'';width:28px;height:1px;background:var(--gold);
}
h1.cover-title {
  font-family:'Syne',sans-serif;
  font-size:clamp(52px,9vw,108px);
  font-weight:800;
  line-height:.95;
  letter-spacing:-.04em;
  color:var(--white);
  margin-bottom:8px;
}
h1.cover-title em { font-style:italic;color:var(--gold); font-weight:600; }
.cover-subtitle {
  font-family:'Syne',sans-serif;
  font-size:clamp(16px,2.5vw,26px);
  font-weight:400;
  color:var(--mist);
  margin-bottom:56px;
  letter-spacing:-.01em;
}
.cover-meta-strip {
  position:relative;z-index:2;
  background:var(--surface);
  border-top:1px solid var(--border2);
  padding:20px clamp(24px,6vw,80px);
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:0;
}
.cover-meta-item {
  padding:0 24px 0 0;
  border-right:1px solid var(--border);
}
.cover-meta-item:last-child{border-right:none;}
.cmeta-label {
  font-family:'DM Mono',monospace;font-size:9.5px;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--mist);margin-bottom:5px;
}
.cmeta-val {
  font-family:'Syne',sans-serif;font-size:14px;font-weight:600;
  color:var(--white);
}
@media(max-width:720px){
  .cover-meta-strip{grid-template-columns:1fr 1fr;gap:20px;}
  .cover-meta-item{border-right:none;}
}

/* ── NAV ── */
#nav {
  position:sticky;top:0;z-index:200;
  background:rgba(11,12,14,.96);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border2);
  padding:0 clamp(24px,6vw,80px);
  display:flex;align-items:center;gap:4px;
  overflow-x:auto;
  scrollbar-width:none;
}
#nav::-webkit-scrollbar{display:none;}
.nav-item {
  font-family:'DM Mono',monospace;font-size:11px;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--mist);
  padding:14px 14px;
  white-space:nowrap;
  cursor:pointer;
  border-bottom:2px solid transparent;
  transition:all .2s;
  text-decoration:none;
  display:block;
}
.nav-item:hover{color:var(--white);}
.nav-item.active{color:var(--gold);border-bottom-color:var(--gold);}

/* ── SECTIONS ── */
.section {
  padding:clamp(64px,8vw,112px) clamp(24px,6vw,80px);
  border-bottom:1px solid var(--border);
}
.section:last-child{border-bottom:none;}
.section-header {
  display:flex;align-items:flex-start;justify-content:space-between;
  gap:24px;margin-bottom:48px;flex-wrap:wrap;
}
.section-label {
  font-family:'DM Mono',monospace;font-size:10px;
  letter-spacing:.2em;text-transform:uppercase;
  color:var(--gold);margin-bottom:10px;
  display:flex;align-items:center;gap:8px;
}
.section-label::before{content:'';width:20px;height:1px;background:var(--gold);}
h2.section-title {
  font-family:'Syne',sans-serif;
  font-size:clamp(28px,4vw,46px);
  font-weight:700;
  letter-spacing:-.03em;
  line-height:1.05;
  color:var(--white);
}
.section-desc {
  font-size:16px;color:var(--mist2);
  max-width:520px;line-height:1.75;
  margin-top:12px;
}

/* ── CALLOUT BOX ── */
.callout {
  border-radius:var(--r2);
  padding:24px 28px;
  margin:0 0 32px;
  display:flex;gap:16px;align-items:flex-start;
}
.callout.gold{background:var(--gold-dim);border:1px solid var(--gold-border);}
.callout.teal{background:var(--teal-dim);border:1px solid rgba(62,207,178,.25);}
.callout.red{background:var(--red-dim);border:1px solid rgba(232,93,93,.2);}
.callout.blue{background:var(--blue-dim);border:1px solid rgba(91,156,246,.2);}
.callout-icon{font-size:20px;flex-shrink:0;margin-top:2px;}
.callout-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14.5px;color:var(--white);margin-bottom:5px;}
.callout-body{font-size:13.5px;color:var(--mist2);line-height:1.65;}

/* ── BADGES ── */
.badge {
  display:inline-flex;align-items:center;gap:5px;
  font-family:'DM Mono',monospace;font-size:10px;
  font-weight:500;letter-spacing:.08em;
  padding:3px 9px;border-radius:4px;
  white-space:nowrap;
}
.badge.p0{background:rgba(232,93,93,.18);color:#F08080;border:1px solid rgba(232,93,93,.25);}
.badge.p1{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(240,168,78,.25);}
.badge.p2{background:var(--blue-dim);color:var(--blue);border:1px solid rgba(91,156,246,.2);}
.badge.ops{background:rgba(168,127,232,.15);color:var(--purple);border:1px solid rgba(168,127,232,.2);}
.badge.revenue{background:var(--green-dim);color:var(--green);border:1px solid rgba(82,201,123,.2);}
.badge.quality{background:var(--teal-dim);color:var(--teal);border:1px solid rgba(62,207,178,.2);}
.badge.growth{background:var(--gold-dim);color:var(--gold2);border:1px solid var(--gold-border);}
.badge.risk{background:var(--red-dim);color:var(--red);border:1px solid rgba(232,93,93,.2);}
.badge.phase{background:var(--surface3);color:var(--mist2);border:1px solid var(--border2);}
.badge-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}

/* ── CHIP ── */
.chip {
  display:inline-flex;align-items:center;gap:5px;
  font-family:'DM Mono',monospace;font-size:10.5px;
  padding:4px 10px;border-radius:20px;
  background:var(--surface3);border:1px solid var(--border2);
  color:var(--mist2);white-space:nowrap;
}
.chip.data{background:rgba(91,156,246,.1);border-color:rgba(91,156,246,.2);color:var(--blue);}
.chip.action{background:rgba(212,168,67,.1);border-color:rgba(212,168,67,.2);color:var(--gold2);}
.chip.tech{background:rgba(62,207,178,.08);border-color:rgba(62,207,178,.2);color:var(--teal);}
.chip-row{display:flex;gap:7px;flex-wrap:wrap;margin-top:12px;}

/* ── FEATURE CARDS ── */
.feature-card {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r2);
  margin-bottom:12px;
  overflow:hidden;
  transition:border-color .2s;
}
.feature-card:hover{border-color:var(--border2);}
.feature-card.open{border-color:var(--gold-border);}
.fc-header {
  display:flex;align-items:center;justify-content:space-between;
  padding:20px 24px;cursor:pointer;
  gap:16px;
  user-select:none;
}
.fc-left{display:flex;align-items:center;gap:14px;flex:1;min-width:0;}
.fc-num {
  font-family:'DM Mono',monospace;font-size:11px;
  color:var(--mist);letter-spacing:.08em;
  flex-shrink:0;min-width:28px;
}
.fc-title {
  font-family:'Syne',sans-serif;font-size:15px;font-weight:600;
  color:var(--white);
}
.fc-badges{display:flex;gap:6px;flex-shrink:0;flex-wrap:wrap;}
.fc-chevron {
  width:22px;height:22px;border-radius:50%;
  background:var(--surface3);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .25s;font-size:12px;color:var(--mist);
}
.feature-card.open .fc-chevron{background:var(--gold-dim);border-color:var(--gold-border);color:var(--gold);transform:rotate(180deg);}
.fc-body {
  display:none;
  padding:0 24px 24px;
  border-top:1px solid var(--border);
}
.fc-body.open{display:block;}
.fc-desc{font-size:14px;color:var(--mist2);line-height:1.7;margin:18px 0 14px;}
.fc-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;}
@media(max-width:640px){.fc-grid{grid-template-columns:1fr;}}
.fc-block{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;}
.fc-block-label{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--mist);margin-bottom:8px;}
.fc-block-content{font-size:13.5px;color:var(--mist2);line-height:1.65;}
.fc-metric{display:flex;justify-content:space-between;align-items:baseline;padding:8px 0;border-bottom:1px solid var(--border);}
.fc-metric:last-child{border-bottom:none;}
.fc-metric-label{font-size:13px;color:var(--mist);}
.fc-metric-val{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--white);}

/* ── STATS GRID ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:48px;}
@media(max-width:800px){.stats-grid{grid-template-columns:1fr 1fr;}}
.stat-card{background:var(--surface);padding:28px 24px;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--gold);}
.stat-n{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;color:var(--gold2);letter-spacing:-.02em;line-height:1;}
.stat-l{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--mist);margin-top:8px;}
.stat-sub{font-size:12.5px;color:var(--mist2);margin-top:6px;line-height:1.5;}

/* ── PITCH DECK SLIDES ── */
.pitch-slide{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r2);
  padding:36px;
  margin-bottom:16px;
  position:relative;
  overflow:hidden;
}
.pitch-slide.featured{
  background:linear-gradient(135deg,var(--surface2),var(--surface3));
  border-color:var(--gold-border);
}
.pitch-slide::before{
  content:'';position:absolute;top:0;left:0;width:3px;height:100%;
  background:var(--gold);
}
.pitch-slide.featured::before{background:linear-gradient(180deg,var(--gold2),var(--teal));}
.pitch-slide-num{
  font-family:'DM Mono',monospace;font-size:10px;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--gold);margin-bottom:12px;display:block;
}
.pitch-slide-title{
  font-family:'Syne',sans-serif;font-size:22px;font-weight:700;
  color:var(--white);margin-bottom:12px;letter-spacing:-.02em;
}
.pitch-slide-body{font-size:14px;color:var(--mist2);line-height:1.75;}
.pitch-bullets{margin-top:16px;display:flex;flex-direction:column;gap:9px;}
.pb{display:flex;gap:10px;align-items:flex-start;font-size:13.5px;color:var(--mist2);}
.pb::before{content:'→';color:var(--gold);font-size:12px;flex-shrink:0;margin-top:2px;}
.pitch-metrics-row{display:flex;gap:32px;margin-top:20px;flex-wrap:wrap;}
.pm-box{text-align:center;}
.pm-box-n{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;color:var(--gold2);}
.pm-box-l{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--mist);margin-top:3px;}

/* ── ADMIN PANEL SPECS ── */
.admin-section-title{
  font-family:'Syne',sans-serif;font-size:18px;font-weight:700;
  color:var(--white);margin-bottom:16px;margin-top:36px;
  letter-spacing:-.01em;
  display:flex;align-items:center;gap:10px;
}
.admin-section-title::before{content:'';width:4px;height:20px;background:var(--gold);border-radius:2px;flex-shrink:0;}
.admin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:800px){.admin-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:560px){.admin-grid{grid-template-columns:1fr;}}
.admin-card{
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:var(--r);
  padding:18px 20px;
  transition:all .2s;
}
.admin-card:hover{border-color:var(--border2);background:var(--surface3);}
.admin-card-icon{font-size:20px;margin-bottom:10px;}
.admin-card-title{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold2);margin-bottom:6px;}
.admin-card-desc{font-size:13px;color:var(--mist2);line-height:1.6;}
.data-schema{
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:var(--r);
  overflow:hidden;
  margin-bottom:20px;
}
.data-schema-header{
  background:var(--surface3);
  padding:12px 18px;
  font-family:'DM Mono',monospace;font-size:10px;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--mist2);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.data-row{
  display:grid;grid-template-columns:200px 120px 1fr;
  padding:11px 18px;
  border-bottom:1px solid var(--border);
  align-items:center;gap:12px;
}
.data-row:last-child{border-bottom:none;}
.data-row:hover{background:var(--surface3);}
.data-field{font-family:'DM Mono',monospace;font-size:12px;color:var(--teal);}
.data-type{font-family:'DM Mono',monospace;font-size:11px;color:var(--gold);}
.data-desc{font-size:12.5px;color:var(--mist2);}
@media(max-width:700px){.data-row{grid-template-columns:1fr;gap:4px;}.data-type{display:inline;}}

/* ── PHASING TABLE ── */
.phase-table{width:100%;border-collapse:collapse;margin-top:8px;}
.phase-table th{
  font-family:'DM Mono',monospace;font-size:10px;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--mist);
  background:var(--surface2);
  padding:12px 18px;text-align:left;
  border-bottom:1px solid var(--border2);
}
.phase-table td{
  padding:13px 18px;font-size:13.5px;
  border-bottom:1px solid var(--border);
  vertical-align:top;
}
.phase-table tr:hover td{background:var(--surface2);}
.phase-table .phase-tag{
  font-family:'DM Mono',monospace;font-size:11px;
  letter-spacing:.08em;
  display:inline-flex;align-items:center;gap:5px;
}
.ptag-1{color:var(--teal);}
.ptag-2{color:var(--gold);}
.ptag-3{color:var(--purple);}
.phase-table .wk{font-family:'DM Mono',monospace;font-size:12px;color:var(--mist);}
.phase-table .feat-list{display:flex;flex-direction:column;gap:4px;}
.phase-table .feat-list li{font-size:12.5px;color:var(--mist2);list-style:none;display:flex;gap:6px;}
.phase-table .feat-list li::before{content:'·';color:var(--gold);flex-shrink:0;}
.phase-table .kpi{font-family:'DM Mono',monospace;font-size:12px;color:var(--green);}
.phase-table .cost{font-family:'DM Mono',monospace;font-size:12px;color:var(--amber);}

/* ── DIVIDER ── */
.divider{height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);margin:0;}

/* ── RISK MATRIX ── */
.risk-row{
  display:flex;align-items:flex-start;gap:16px;
  padding:16px 20px;
  border-radius:var(--r);
  background:var(--surface);
  border:1px solid var(--border);
  margin-bottom:10px;
}
.risk-score{
  width:44px;height:44px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-size:16px;font-weight:800;
  flex-shrink:0;
}
.rs-high{background:var(--red-dim);color:var(--red);border:1px solid rgba(232,93,93,.3);}
.rs-med{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(240,168,78,.3);}
.rs-low{background:var(--green-dim);color:var(--green);border:1px solid rgba(82,201,123,.3);}
.risk-title{font-family:'DM Mono',monospace;font-size:12px;font-weight:500;color:var(--white);margin-bottom:4px;letter-spacing:.04em;}
.risk-body{font-size:13px;color:var(--mist2);line-height:1.6;}
.risk-mitigation{font-size:12px;color:var(--teal);margin-top:5px;}

/* ── COMPARISON TABLE ── */
.comp-table{width:100%;border-collapse:collapse;}
.comp-table th{
  font-family:'DM Mono',monospace;font-size:9.5px;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--mist);padding:12px 16px;text-align:left;
  border-bottom:1px solid var(--border2);background:var(--surface2);
}
.comp-table td{padding:12px 16px;font-size:13px;border-bottom:1px solid var(--border);}
.comp-table tr.sourced-row td{background:var(--gold-dim);font-weight:600;}
.comp-table tr:hover:not(.sourced-row) td{background:var(--surface2);}
.ck{color:var(--teal);font-size:15px;}.cx{color:rgba(255,255,255,.18);font-size:15px;}.cpart{color:var(--amber);font-size:12px;}
.cs-tag{background:var(--gold-dim);color:var(--gold2);border:1px solid var(--gold-border);font-family:'DM Mono',monospace;font-size:10px;padding:2px 8px;border-radius:4px;letter-spacing:.06em;}

/* ── FOOTER ── */
.doc-footer{
  background:var(--surface);
  border-top:1px solid var(--border2);
  padding:32px clamp(24px,6vw,80px);
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:16px;
}
.doc-footer-logo{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--gold);}
.doc-footer-note{font-family:'DM Mono',monospace;font-size:10.5px;letter-spacing:.08em;color:var(--mist);}

/* ── ANIMATIONS ── */
.fade-in{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;}
.fade-in.visible{opacity:1;transform:none;}

/* ── PROGRESS BAR ── */
